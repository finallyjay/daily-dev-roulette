---
import SpeedInsights from "@vercel/speed-insights/astro";
import "../styles/global.css";
import type { Profile } from "../lib/daily";

interface Props {
  title?: string;
  description?: string;
  profile?: Profile | null;
}
const {
  title = "daily.dev Roulette",
  description = "Spin the cylinder on your forgotten daily.dev bookmarks — read it, or pull the trigger and delete it forever. A darkly funny way to clear your backlog.",
  profile = null,
} = Astro.props;

// Absolute URLs resolved at request time, so OG works on any deploy domain.
const canonical = new URL(Astro.url.pathname, Astro.url.origin).href;
const ogImage = new URL("/og-image.png", Astro.url.origin).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#1a120b" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="daily.dev Roulette" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Rye&family=Special+Elite&family=Zilla+Slab:ital,wght@0,400;0,500;0,700;1,400&display=swap"
      rel="stylesheet"
    />

    <SpeedInsights />
  </head>
  <body>
    <header class="topbar">
      <a href="/" class="brand">🎲 daily.dev Roulette</a>
      <div class="user">
        {profile ? (
          <>
            <span class="avatar">
              {profile.image && (
                <img src={profile.image} alt="" referrerpolicy="no-referrer" id="avatar-img" />
              )}
              <span class="avatar-fallback" id="avatar-fallback" class:list={[{ hidden: !!profile.image }]}>
                {(profile.name || profile.username || "?").charAt(0).toUpperCase()}
              </span>
            </span>
            <span class="uname">{profile.name || profile.username || "you"}</span>
            <button class="signout" id="signout-btn">Sign out</button>
          </>
        ) : (
          <span class="muted">not signed in</span>
        )}
      </div>
    </header>
    <main>
      <slot />
    </main>

    <script>
      const avatarImg = document.getElementById("avatar-img");
      avatarImg?.addEventListener("error", () => {
        avatarImg.style.display = "none";
        document.getElementById("avatar-fallback")?.classList.remove("hidden");
      });

      const btn = document.getElementById("signout-btn");
      btn?.addEventListener("click", async () => {
        await fetch("/api/auth", { method: "DELETE" });
        try { localStorage.removeItem("ddr_progress"); } catch {}
        window.location.href = "/";
      });
    </script>
  </body>
</html>
