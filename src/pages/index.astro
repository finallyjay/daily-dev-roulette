---
import Layout from "../layouts/Layout.astro";
import { currentUser } from "../lib/auth";

const profile = await currentUser(Astro.cookies);
---

<Layout title="daily.dev Roulette" profile={profile}>
  <div class="reveal r1" style="text-align:center;">
    <p class="kicker">★ ★ ★ &nbsp; THE TERRITORY OF &nbsp; ★ ★ ★</p>
    <h1>daily.dev Roulette</h1>
    <p class="tagline">Round up your forgotten bookmarks. Read 'em or bury 'em.</p>
  </div>

  {!profile && (
    <section class="panel reveal r2" style="margin-bottom:1.4rem;">
      <h2>Show your papers</h2>
      <p class="card-meta">Paste your daily.dev API token (<a href="https://app.daily.dev/settings/api" target="_blank" rel="noopener">Settings → API</a>, needs a Plus subscription) to ride with your real bookmarks. It stays in a sealed saddlebag — a secure cookie, only for your session.</p>
      <input type="password" id="token" placeholder="daily.dev API token" autocomplete="off" />
      <button class="btn-primary" id="signin">Sign in</button>
      <p class="error" id="login-error"></p>
    </section>
  )}

  {profile && (
    <p class="tagline reveal r2" style="margin-top:-1rem;">Well howdy, {profile.name || profile.username || "stranger"}.</p>
  )}

  <section class="panel reveal r3">
    <h2 style="margin-bottom:1rem;">Choose your duel</h2>

    <div class="mode-card">
      <span class="mode-stamp">NEW</span>
      <div class="mode-head">
        <span class="mode-icon">🔖</span>
        <div>
          <div class="mode-title">Bookmarks Roulette</div>
          <div class="card-meta">Spin a bookmark. Pardon it, or shoot it dead.</div>
        </div>
      </div>
      {profile && (
        <p class="card-meta" style="margin-top:0.6rem;">There's <b id="bm-count">…</b> in the chamber, partner.</p>
      )}
      <div class="row" style="margin-top:0.9rem;">
        {profile && (
          <a href="/roulette" style="flex:1; text-decoration:none;">
            <button class="btn-primary">🤠 Draw</button>
          </a>
        )}
        <a href="/roulette?demo=1" style="flex:1; text-decoration:none;">
          <button class="btn-ghost" style="width:100%;">▶ Demo</button>
        </a>
      </div>
    </div>

    <p class="coming">— more duels comin' to town —</p>
  </section>
</Layout>

<script>
  const signin = document.getElementById("signin");
  signin?.addEventListener("click", async () => {
    const token = (document.getElementById("token") as HTMLInputElement).value.trim();
    const err = document.getElementById("login-error")!;
    err.textContent = "";
    if (!token) { err.textContent = "Paste a token first, partner."; return; }
    (signin as HTMLButtonElement).disabled = true;
    try {
      const res = await fetch("/api/auth", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ token }),
      });
      if (!res.ok) throw new Error((await res.json()).error || "Sign-in failed");
      try { localStorage.removeItem("ddr_progress"); } catch {}
      window.location.href = "/";
    } catch (e: any) {
      err.textContent = String(e.message || e);
      (signin as HTMLButtonElement).disabled = false;
    }
  });

  const countEl = document.getElementById("bm-count");
  if (countEl) {
    fetch("/api/bookmarks")
      .then((r) => r.json())
      .then((d) => { countEl.textContent = String(d.items?.length ?? 0); })
      .catch(() => { countEl.textContent = "?"; });
  }
</script>

<style>
  .kicker {
    font-family: var(--font-type);
    letter-spacing: 0.35em;
    font-size: 0.7rem;
    color: var(--brass);
    margin: 0 0 0.4rem;
  }
  .mode-card {
    position: relative;
    border: 2px solid var(--ink);
    border-radius: 3px;
    padding: 1.2rem;
    background: repeating-linear-gradient(45deg, rgba(0,0,0,0.015) 0 8px, transparent 8px 16px), #f1e6c9;
    box-shadow: 0 3px 0 rgba(0,0,0,0.25);
  }
  .mode-head { display: flex; gap: 0.9rem; align-items: center; }
  .mode-icon { font-size: 2rem; }
  .mode-title { font-family: var(--font-display); font-size: 1.25rem; color: var(--ink); }
  .mode-stamp {
    position: absolute; top: -12px; right: 14px;
    font-family: var(--font-display); font-size: 0.7rem;
    color: var(--blood); border: 2px solid var(--blood);
    padding: 2px 8px; border-radius: 3px; transform: rotate(7deg);
    background: #f1e6c9; letter-spacing: 0.1em;
  }
  .coming {
    text-align: center; font-family: var(--font-type);
    color: var(--ink-soft); font-size: 0.8rem; margin: 1.3rem 0 0;
  }

  /* staggered entrance */
  .reveal { animation: rise 0.7s cubic-bezier(0.16,1,0.3,1) both; }
  .r1 { animation-delay: 0.05s; }
  .r2 { animation-delay: 0.2s; }
  .r3 { animation-delay: 0.35s; }
  @keyframes rise {
    from { opacity: 0; transform: translateY(22px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
